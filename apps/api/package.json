{
  "name": "@mini-sentry/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc --noEmit && esbuild src/main.ts --bundle --platform=node --outfile=dist/main.js --external:@prisma/client",
    "start": "node dist/main.js",
    "type-check": "tsc --noEmit",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/rate-limit": "^10.0.0",
    "@jridgewell/trace-mapping": "^0.3.25",
    "@mini-sentry/shared": "workspace:*",
    "@prisma/client": "^5.14.0",
    "bcryptjs": "^2.4.3",
    "fastify": "^5.8.3",
    "ioredis": "^5.3.2",
    "jose": "^5.10.0",
    "nodemailer": "^8.0.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^6.4.15",
    "esbuild": "^0.25.0",
    "prisma": "^5.14.0",
    "tsx": "^4.15.1",
    "typescript": "^5.4.5"
  }
}
