{
  "name": "@mini-sentry/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc --noEmit && esbuild src/main.ts --bundle --platform=node --outfile=dist/main.js --external:@prisma/client",
    "start": "node dist/main.js",
    "type-check": "tsc --noEmit",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@jridgewell/trace-mapping": "^0.3.25",
    "@mini-sentry/shared": "workspace:*",
    "@prisma/client": "^5.14.0",
    "fastify": "^4.27.0",
    "ioredis": "^5.3.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "esbuild": "^0.21.5",
    "prisma": "^5.14.0",
    "tsx": "^4.15.1",
    "typescript": "^5.4.5"
  }
}
