{
  "name": "@mini-sentry/cli",
  "version": "0.0.1",
  "description": "CLI for uploading source maps to Mini Sentry",
  "bin": {
    "mini-sentry-upload": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_ORG/mini-sentry"
  },
  "keywords": ["sentry", "error-tracking", "source-maps", "cli", "mini-sentry"]
}
