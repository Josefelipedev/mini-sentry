{
  "name": "@mini-sentry/browser",
  "version": "0.0.1",
  "description": "Lightweight browser SDK for self-hosted Mini Sentry error monitoring",
  "keywords": ["error-tracking", "sentry", "monitoring", "browser", "sdk", "mini-sentry"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_ORG/mini-sentry"
  },
  "homepage": "https://github.com/YOUR_ORG/mini-sentry#readme",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "pnpm build && pnpm type-check"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=16"
  }
}
