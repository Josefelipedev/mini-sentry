{
  "name": "@mini-sentry/vue",
  "version": "0.0.1",
  "description": "Vue 3 plugin for Mini Sentry error tracking",
  "keywords": ["mini-sentry", "error-tracking", "vue", "vue3"],
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "pnpm build && pnpm type-check"
  },
  "peerDependencies": {
    "@mini-sentry/browser": "^0.0.1",
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@mini-sentry/browser": "workspace:*",
    "vue": "^3.5.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  },
  "publishConfig": { "access": "public" },
  "repository": { "type": "git", "url": "https://github.com/YOUR_ORG/mini-sentry" }
}
