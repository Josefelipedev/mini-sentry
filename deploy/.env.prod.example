# ── Banco de dados (já rodando na VPS) ──────────────────────────────────────
# Use host.docker.internal para apontar para o Postgres do host
DATABASE_URL="postgresql://USUARIO:SENHA@host.docker.internal:5432/mini_sentry"

# ── Redis (já rodando na VPS) ────────────────────────────────────────────────
REDIS_URL="redis://host.docker.internal:6379"

# ── API ──────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
DASHBOARD_ORIGIN="https://logs.thechats.me"

# Rate limiting
API_RATE_LIMIT_MAX=200
API_RATE_LIMIT_WINDOW_MS=60000
INGEST_RATE_LIMIT_MAX=500
INGEST_RATE_LIMIT_WINDOW_MS=60000

# ── Dashboard ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="https://logs.thechats.me"

# ── Email (opcional — deixe vazio para desativar) ────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Mini Sentry <noreply@thechats.me>"
