{
  "name": "mini-sentry",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter @mini-sentry/api dev",
    "dev:dashboard": "pnpm --filter @mini-sentry/dashboard dev",
    "dev": "pnpm --parallel --filter './apps/*' dev",
    "build": "pnpm -r --filter './packages/*' build && pnpm -r --filter './apps/*' build",
    "type-check": "pnpm -r type-check",
    "db:push": "pnpm --filter @mini-sentry/api db:push",
    "db:migrate": "pnpm --filter @mini-sentry/api db:migrate",
    "db:studio": "pnpm --filter @mini-sentry/api db:studio"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
